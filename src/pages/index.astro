---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import ThemeToggle from "@/components/ThemeToggle.astro";
import PortfolioScene from "@/components/PortfolioScene";
import ResponsiveImage from "@/components/ResponsiveImage.astro";
import { getProjectPresentation } from "@/lib/projectPresentation";
import { getLargestVariant } from "@/lib/generated/image-manifest";
import { getBalancedTitleLines } from "@/lib/titleBreaks";

// --- CONFIGURATION ---
// 1 = Center Aligned (Original)
// 2 = Left Aligned (Bax Style)
// 3 = Split View (Modern Sidebar)
// 4 = Bento / Mosaic View
// 5 = Cinematic Scroll (Full Screen Snap)
const CURRENT_LAYOUT: number = 3;

// ---------------------

const PROFILE = {
    name: "OFAUNS",
    role: "Visual Designer / Motion, Web & Interaction",
    email: "cheny4314@gmail.com",
    bio: "Building cinematic visual systems, motion pieces, web interfaces, and interactive design with a sharp eye for atmosphere and detail.",
    avatar: "/header.jpg",
    links: {
        twitter: "https://x.com/baxartworkz",
        email: "mailto:cheny4314@gmail.com",
    },
};

const SCENE_COLORS = ["#5ddcff", "#8fb4ff", "#f2f6ff", "#9ff3d1", "#ffb39a"];

// Fetch all work items (mdx files)
const portfolioData = await getCollection("work");

// Sort by date descending
const sortedPortfolio = portfolioData.sort(
    (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime(),
);

// Group by genre
const groupedPortfolio = sortedPortfolio.reduce(
    (acc, project) => {
        const genre = project.data.genre || "Motion";
        if (!acc[genre]) acc[genre] = [];
        acc[genre].push(project);
        return acc;
    },
    {} as Record<string, typeof sortedPortfolio>,
);
const genreNames = Object.keys(groupedPortfolio).sort((genreA, genreB) => {
    const aIsFilm = genreA.toLowerCase() === "film";
    const bIsFilm = genreB.toLowerCase() === "film";
    if (aIsFilm === bIsFilm) return 0;
    return aIsFilm ? 1 : -1;
});
const orderedGroupedPortfolio = genreNames.map((genre) => [
    genre,
    groupedPortfolio[genre],
] as const);
// Flatten groupedPortfolio to respect genre ordering for Layout 5
const genreSortedPortfolio = orderedGroupedPortfolio.flatMap(([, projects]) => projects);
const genreMeta = genreNames.reduce(
    (acc, genre, index) => {
        acc[genre] = {
            color: SCENE_COLORS[index % SCENE_COLORS.length],
            index: index + 1,
        };
        return acc;
    },
    {} as Record<string, { color: string; index: number }>,
);
const featuredSceneProjects = genreSortedPortfolio.slice(0, 7).map((project) => {
    const genre = project.data.genre || "Motion";

    return {
        title: project.data.title,
        genre,
        thumbnail: getLargestVariant(project.data.thumbnail),
        color: genreMeta[genre]?.color || SCENE_COLORS[0],
    };
});
---

<Layout title="OFAUNS Portfolio" description={PROFILE.role} image="/og-image.png">
    {
        /* =========================================
        LAYOUT 1: Centered / Original
       ========================================= */
    }
    {
        CURRENT_LAYOUT === 1 && (
            <main class="container mx-auto px-4 py-12 max-w-6xl animate-blur-in">
                {/* Profile Section */}
                <header class="flex flex-col items-center justify-center mb-16 space-y-6 relative">
                    <div class="absolute right-0 top-0 md:top-auto">
                        <ThemeToggle />
                    </div>

                    <div class="profile-flip-container w-24 h-24 md:w-32 md:h-32 relative cursor-pointer [perspective:1000px] z-50 group hover:scale-110 transition-transform duration-500">
                        <div class="profile-flip-inner w-full h-full relative transition-[transform] duration-700 ease-in-out [transform-style:preserve-3d]">
                            <ResponsiveImage
                                src={PROFILE.avatar}
                                alt="Profile"
                                class="object-cover w-full h-full absolute inset-0 bg-muted [backface-visibility:hidden]"
                                decoding="async"
                                fetchpriority="high"
                                loading="eager"
                                sizes="8rem"
                            />
                            <ResponsiveImage
                                src="/melogo.png"
                                alt="Logo"
                                class="object-cover w-full h-full absolute inset-0 bg-white [backface-visibility:hidden] flip-180"
                                loading="lazy"
                                decoding="async"
                                sizes="8rem"
                            />
                        </div>
                    </div>

                    <div class="text-center max-w-lg space-y-4">
                        <h1 class="text-2xl font-bold tracking-tight animate-blur-in delay-200">
                            <a href="/about" class="hover:text-primary transition-colors">
                                {PROFILE.name}
                            </a>
                        </h1>
                        <p class="text-muted-foreground leading-relaxed animate-blur-in delay-300">
                            {PROFILE.bio}
                        </p>
                        <div class="flex gap-4 justify-center text-muted-foreground text-sm pt-2 animate-blur-in delay-400">
                            <a
                                href={PROFILE.links.twitter}
                                class="hover:text-foreground transition-colors"
                            >
                                Twitter
                            </a>
                            <a
                                href={PROFILE.links.email}
                                class="hover:text-foreground transition-colors"
                            >
                                Email
                            </a>
                        </div>
                    </div>
                </header>

                {/* Grouped Video Grid */}
                <div class="space-y-16">
                    {orderedGroupedPortfolio.map(
                        ([genre, projects]) => (
                            <section class="space-y-6">
                                <h2 class="text-xl font-semibold tracking-wider uppercase mb-6">
                                    {genre}
                                </h2>

                                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
                                    {projects.map((project, index) => (
                                        <a
                                            href={`/work/${project.slug}`}
                                            class={`group block space-y-3 cursor-pointer animate-blur-in`}
                                            style={`animation-delay: ${Math.min((index + 1) * 100, 600)}ms`}
                                        >
                                            {/* Thumbnail Container with 16:9 Aspect Ratio */}
                                            <div class="relative aspect-video overflow-hidden bg-muted group-hover:opacity-90 transition-opacity">
                                                <ResponsiveImage
                                                    src={project.data.thumbnail}
                                                    alt={project.data.title}
                                                    class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-105"
                                                    loading="lazy"
                                                    decoding="async"
                                                    sizes="(max-width: 768px) 92vw, (max-width: 1200px) 44vw, 30vw"
                                                />
                                                <div class="absolute inset-0 bg-black/50 opacity-0 group-hover:opacity-100 transition-opacity flex items-center justify-center">
                                                    <span class="text-white font-medium tracking-wide">
                                                        VIEW PROJECT
                                                    </span>
                                                </div>
                                            </div>

                                            {/* Info */}
                                            <div class="space-y-1">
                                                <h3 class="font-medium text-lg leading-none group-hover:text-primary transition-colors">
                                                    {project.data.title}
                                                </h3>

                                                <div class="flex items-center justify-between">
                                                    <p class="text-sm text-muted-foreground">
                                                        {project.data.client} •{" "}
                                                        {new Date(
                                                            project.data.date,
                                                        ).getFullYear()}
                                                    </p>

                                                    {/* Roles */}
                                                    <div class="relative group/roles flex items-center justify-end">
                                                        <div class="flex items-center gap-1.5 cursor-help">
                                                            {project.data.role
                                                                .length > 0 && (
                                                                <span class="text-[10px] font-medium bg-muted/30 px-1.5 py-0.5 text-muted-foreground uppercase tracking-wider">
                                                                    {
                                                                        project
                                                                            .data
                                                                            .role[0]
                                                                    }
                                                                </span>
                                                            )}
                                                            {project.data.role
                                                                .length > 1 && (
                                                                <span class="text-[10px] text-muted-foreground font-medium">
                                                                    +
                                                                    {project
                                                                        .data
                                                                        .role
                                                                        .length -
                                                                        1}
                                                                </span>
                                                            )}
                                                        </div>

                                                        {/* Hover Popover */}
                                                        <div class="absolute bottom-full right-0 mb-2 w-max hidden group-hover/roles:flex flex-col gap-1 p-2 bg-popover shadow-lg z-20">
                                                            {project.data.role.map(
                                                                (role) => (
                                                                    <span class="text-xs text-popover-foreground">
                                                                        {role}
                                                                    </span>
                                                                ),
                                                            )}
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </a>
                                    ))}
                                </div>
                            </section>
                        ),
                    )}
                </div>

                <footer class="py-6 flex flex-col items-center gap-4 text-sm text-muted-foreground mt-12">
                    <div class="flex flex-col items-center gap-1 text-center">
                        <p class="font-medium tracking-wide">
                            &copy; {new Date().getFullYear()} {PROFILE.name}.
                            All rights reserved.
                        </p>
                        <a
                            href={PROFILE.links.email}
                            class="hover:text-primary transition-colors"
                        >
                            {PROFILE.email}
                        </a>
                    </div>

                    <button
                        id="back-to-top"
                        class="p-2 hover:bg-muted transition-all opacity-0 translate-y-4 data-[visible=true]:opacity-100 data-[visible=true]:translate-y-0"
                        aria-label="Back to top"
                        title="Back to top"
                    >
                        <svg
                            xmlns="http://www.w3.org/2000/svg"
                            width="16"
                            height="16"
                            viewBox="0 0 24 24"
                            fill="none"
                            stroke="currentColor"
                            stroke-width="2"
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            class="lucide lucide-arrow-up"
                        >
                            <path d="m18 15-6-6-6 6" />
                        </svg>
                    </button>
                </footer>
            </main>
        )
    }

    {
        /* =========================================
        LAYOUT 2: Left Aligned / Bax Style
        ========================================= */
    }
    {
        CURRENT_LAYOUT === 2 && (
            <main class="container mx-auto px-6 py-12 max-w-[1800px] animate-blur-in">
                <div class="absolute right-6 top-6 z-50">
                    <ThemeToggle />
                </div>

                {/* Header Section */}
                <header class="mb-20 pt-10 md:pt-20">
                    <div class="flex flex-col md:flex-row gap-8 items-start">
                        <div class="profile-flip-container w-32 h-32 md:w-40 md:h-40 shrink-0 rounded-xl border border-border/50 cursor-pointer [perspective:1000px] z-50 group hover:scale-110 transition-transform duration-500">
                            <div class="profile-flip-inner w-full h-full relative transition-[transform] duration-700 ease-in-out [transform-style:preserve-3d]">
                                <ResponsiveImage
                                    src={PROFILE.avatar}
                                    alt="Profile"
                                    class="object-cover w-full h-full absolute inset-0 rounded-xl bg-muted [backface-visibility:hidden]"
                                    decoding="async"
                                    fetchpriority="high"
                                    loading="eager"
                                    sizes="10rem"
                                />
                                <ResponsiveImage
                                    src="/melogo.png"
                                    alt="Logo"
                                    class="object-cover w-full h-full absolute inset-0 rounded-xl bg-white [backface-visibility:hidden] flip-180"
                                    loading="lazy"
                                    decoding="async"
                                    sizes="10rem"
                                />
                            </div>
                        </div>

                        <div class="space-y-5 max-w-3xl pt-2">
                            <h1 class="text-5xl md:text-7xl font-black tracking-tighter text-foreground font-display uppercase animate-blur-in delay-200">
                                <a href="/about" class="hover:text-primary transition-colors">
                                    {PROFILE.name}
                                </a>
                            </h1>

                            <div class="space-y-1 text-base md:text-lg text-muted-foreground animate-blur-in delay-300">
                                <p class="font-medium text-foreground">
                                    {PROFILE.role}
                                </p>
                                <p>Contact: {PROFILE.email}</p>
                                <p class="text-sm md:text-base leading-relaxed pt-2 max-w-2xl text-muted-foreground/80">
                                    {PROFILE.bio}
                                </p>
                            </div>
                        </div>
                    </div>
                </header>

                <div class="w-full h-px bg-border/40 mb-12" />

                {/* Works Section */}
                <div class="space-y-4 relative">
                    {orderedGroupedPortfolio.map(
                        ([genre, projects]) => (
                            <section class="mb-24">
                                <h3 class="text-xl font-bold tracking-tight mb-8 text-foreground/90">
                                    {genre} Designs
                                </h3>

                                <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-12">
                                    {projects.map((project, index) => (
                                        <a
                                            href={`/work/${project.slug}`}
                                            class={`group block space-y-4 cursor-pointer animate-blur-in`}
                                            style={`animation-delay: ${Math.min((index + 1) * 100 + 400, 1000)}ms`}
                                        >
                                            {/* Thumbnail */}
                                            <div class="relative aspect-video overflow-hidden bg-muted rounded-md border border-border/50 transition-all duration-500 group-hover:border-primary/50">
                                                <ResponsiveImage
                                                    src={project.data.thumbnail}
                                                    alt={project.data.title}
                                                    class="object-cover w-full h-full transition-transform duration-700 group-hover:scale-105"
                                                    loading="lazy"
                                                    decoding="async"
                                                    sizes="(max-width: 768px) 92vw, (max-width: 1200px) 44vw, 30vw"
                                                />
                                                {/* Overlay */}
                                                <div class="absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end p-4">
                                                    {/* Optional overlay content */}
                                                </div>
                                            </div>

                                            {/* Info */}
                                            <div class="flex justify-between items-start gap-4">
                                                <div class="space-y-1">
                                                    <h4 class="font-bold text-lg leading-tight group-hover:text-primary transition-colors">
                                                        {project.data.title}
                                                    </h4>
                                                    <p class="text-xs text-muted-foreground/80">
                                                        {project.data.client}
                                                    </p>
                                                </div>
                                                <span class="text-xs font-mono text-muted-foreground/60">
                                                    {new Date(
                                                        project.data.date,
                                                    ).getFullYear()}
                                                </span>
                                            </div>
                                        </a>
                                    ))}
                                </div>
                                <div class="flex items-center gap-4 mb-10" />
                            </section>
                        ),
                    )}
                </div>

                <footer class="py-12 border-t border-border/40 mt-20">
                    <div class="flex justify-between items-center text-sm text-muted-foreground">
                        <p>
                            &copy; {new Date().getFullYear()} {PROFILE.name}.
                            All rights reserved.
                        </p>
                        <div class="flex gap-4">
                            <a
                                href={PROFILE.links.twitter}
                                class="hover:text-foreground"
                            >
                                Twitter
                            </a>
                            <a
                                href={PROFILE.links.email}
                                class="hover:text-foreground"
                            >
                                Email
                            </a>
                        </div>
                    </div>
                </footer>
            </main>
        )
    }

    {
        /* =========================================
        LAYOUT 3: Split View (Modern Sidebar)
        ========================================= */
    }
    {
        CURRENT_LAYOUT === 3 && (
            <div class="portfolio-home relative min-h-screen overflow-hidden bg-background">
                <PortfolioScene
                    client:media="(min-width: 1100px) and (prefers-reduced-motion: no-preference)"
                    projectCount={sortedPortfolio.length}
                    categories={genreNames}
                    featuredProjects={featuredSceneProjects}
                />

                <div class="portfolio-theme-toggle animate-blur-in delay-300">
                    <ThemeToggle />
                </div>

                <div class="portfolio-shell portfolio-shell--cinematic relative z-10 min-h-screen">
                    <section class="portfolio-race-hero" aria-labelledby="home-title">
                        <div class="portfolio-hero-copy">
                            <p class="portfolio-hero-kicker portfolio-text-wipe delay-100">
                                Motion / Web / Interaction
                            </p>
                            <h1
                                id="home-title"
                                class="portfolio-home-title portfolio-text-wipe portfolio-text-wipe--title delay-200"
                            >
                                <a href="/about">
                                    {PROFILE.name}
                                </a>
                            </h1>
                            <p class="portfolio-hero-role portfolio-text-wipe delay-300">
                                {PROFILE.role}
                            </p>
                            <p class="portfolio-hero-bio portfolio-text-wipe delay-400">
                                {PROFILE.bio}
                            </p>
                            <div class="portfolio-hero-actions animate-blur-in delay-500">
                                <a class="portfolio-action portfolio-chip" href="#work">
                                    Explore Work
                                </a>
                                <a
                                    class="portfolio-action portfolio-action--ghost portfolio-chip"
                                    href={PROFILE.links.email}
                                >
                                    Email
                                </a>
                            </div>
                            <nav
                                class="portfolio-category-rails animate-blur-in delay-600"
                                aria-label="Jump to portfolio category"
                            >
                                {genreNames.map((genre, index) => (
                                    <a
                                        href={`#${genre}`}
                                        data-scene-project="true"
                                        data-scene-title={genre}
                                        data-scene-genre={genre}
                                        data-scene-color={
                                            genreMeta[genre]?.color ||
                                            SCENE_COLORS[0]
                                        }
                                        class="portfolio-category-rail portfolio-chip"
                                        style={`--scene-accent: ${genreMeta[genre]?.color || SCENE_COLORS[0]}; --rail-index: ${index};`}
                                    >
                                        <span>
                                            {String(index + 1).padStart(2, "0")}
                                        </span>
                                        <strong>
                                            {genre}
                                        </strong>
                                        <i>
                                            {groupedPortfolio[genre]?.length || 0}
                                        </i>
                                    </a>
                                ))}
                            </nav>
                        </div>

                        <div class="portfolio-hero-figure animate-blur-in delay-300">
                            <div class="portfolio-figure-track" aria-hidden="true">
                                <span>Visual Designer</span>
                                <span>Motion</span>
                                <span>Web</span>
                                <span>Interaction</span>
                            </div>
                            <div class="portfolio-figure-frame" data-scroll-zoom="true">
                                <ResponsiveImage
                                    src={PROFILE.avatar}
                                    alt="OFAUNS portrait"
                                    class="h-full w-full object-cover"
                                    decoding="async"
                                    fetchpriority="high"
                                    loading="eager"
                                    sizes="(max-width: 1024px) 92vw, 34vw"
                                />
                                <div class="portfolio-figure-overlay">
                                    <span>OFAUNS</span>
                                    <span>{new Date().getFullYear()}</span>
                                </div>
                            </div>
                            <div class="portfolio-figure-plate">
                                <span>{PROFILE.email}</span>
                                <span>{String(sortedPortfolio.length).padStart(2, "0")} Works / {String(genreNames.length).padStart(2, "0")} Fields</span>
                            </div>
                        </div>

                        <div class="portfolio-water-caption" aria-hidden="true">
                            <span>Liquid Index</span>
                            <span>Speed Layer</span>
                            <span>{new Date().getFullYear()}</span>
                        </div>

                        <div class="portfolio-speed-marquees" aria-hidden="true">
                            <div class="portfolio-hero-marquee portfolio-hero-marquee--wide">
                                <span>Motion</span>
                                <span>Web</span>
                                <span>Interaction</span>
                                <span>Film</span>
                                <span>Visual</span>
                                <span>Motion</span>
                                <span>Web</span>
                            </div>
                            <div class="portfolio-hero-marquee portfolio-hero-marquee--signal">
                                <span>OFAUNS</span>
                                <span>Liquid</span>
                                <span>Design</span>
                                <span>Motion</span>
                                <span>Portfolio</span>
                                <span>OFAUNS</span>
                            </div>
                            <div class="portfolio-hero-marquee portfolio-hero-marquee--track">
                                <span>Visual Designer</span>
                                <span>Motion System</span>
                                <span>Interface</span>
                                <span>Atmosphere</span>
                                <span>Visual Designer</span>
                            </div>
                        </div>

                        <a
                            href="#work"
                            class="portfolio-scroll-cue"
                            aria-label="Scroll to selected work"
                        >
                            <span>Selected Work</span>
                            <i></i>
                        </a>
                    </section>

                    <main id="work" class="portfolio-workstream">
                        <div class="portfolio-sections">
                            {orderedGroupedPortfolio.map(
                                ([genre, projects], genreIndex) => (
                                    <section
                                        id={genre}
                                        class="portfolio-genre-section scroll-mt-20"
                                        style={`--scene-accent: ${genreMeta[genre]?.color || SCENE_COLORS[0]}`}
                                    >
                                        <div class="portfolio-genre-head">
                                            <div>
                                                <p>
                                                    {String(
                                                        genreIndex + 1,
                                                    ).padStart(2, "0")}
                                                </p>
                                                <h2>
                                                    {genre}
                                                </h2>
                                            </div>
                                            <span>
                                                {projects.length} Projects
                                            </span>
                                        </div>

                                        <div class="portfolio-genre-marquee" aria-hidden="true">
                                            <span>{genre}</span>
                                            <span>{genre}</span>
                                            <span>{genre}</span>
                                            <span>{genre}</span>
                                            <span>{genre}</span>
                                        </div>

                                        <div class="portfolio-project-grid">
                                            {projects.map((project, index) => {
                                                const projectPresentation =
                                                    getProjectPresentation(
                                                        project,
                                                    );

                                                return (
                                                    <a
                                                        href={`/work/${project.slug}`}
                                                        data-scene-project="true"
                                                        data-scene-title={
                                                            project.data.title
                                                        }
                                                        data-scene-genre={genre}
                                                        data-scene-color={
                                                            genreMeta[genre]
                                                                ?.color ||
                                                            SCENE_COLORS[0]
                                                        }
                                                        class={`portfolio-project portfolio-project--${projectPresentation.layout} group`}
                                                        style={`--scene-accent: ${genreMeta[genre]?.color || SCENE_COLORS[0]}; --reveal-delay: ${Math.min((index % 4) * 90, 270)}ms`}
                                                    >
                                                        <div
                                                            class="portfolio-project-thumb relative overflow-hidden bg-muted"
                                                            data-scroll-zoom="true"
                                                            data-fit={
                                                                projectPresentation.imageFit
                                                            }
                                                        >
                                                            <ResponsiveImage
                                                                src={
                                                                    project.data
                                                                        .thumbnail
                                                                }
                                                                alt={
                                                                    project.data
                                                                        .title
                                                                }
                                                                class="h-full w-full object-cover transition-transform duration-700 ease-out group-hover:scale-105"
                                                                loading="lazy"
                                                                decoding="async"
                                                                sizes="(max-width: 768px) 92vw, (max-width: 1280px) 44vw, 32vw"
                                                            />
                                                            <div class="portfolio-project-shade" />
                                                            <span class="portfolio-project-mode">
                                                                {
                                                                    projectPresentation.modeLabel
                                                                }
                                                            </span>
                                                            <div class="portfolio-project-view">
                                                                <span class="portfolio-project-view-line" />
                                                                <span>
                                                                    View
                                                                </span>
                                                            </div>
                                                        </div>

                                                        <div class="portfolio-project-body">
                                                            <div class="portfolio-project-meta">
                                                                <span>
                                                                    {String(
                                                                        index +
                                                                            1,
                                                                    ).padStart(
                                                                        2,
                                                                        "0",
                                                                    )}
                                                                </span>
                                                                <span>
                                                                    {new Date(
                                                                        project
                                                                            .data
                                                                            .date,
                                                                    ).getFullYear()}
                                                                </span>
                                                            </div>
                                                            <h3 class="portfolio-project-title">
                                                                {getBalancedTitleLines(
                                                                    project.data
                                                                        .title,
                                                                    {
                                                                        maxLines: 3,
                                                                        targetLength: 18,
                                                                    },
                                                                ).map(
                                                                    (line) => (
                                                                        <span>
                                                                            {line}
                                                                        </span>
                                                                    ),
                                                                )}
                                                            </h3>
                                                            <p class="portfolio-project-intro">
                                                                {
                                                                    projectPresentation.homeIntro
                                                                }
                                                            </p>

                                                            <div class="portfolio-project-footer">
                                                                <span>
                                                                    {project.data.client}
                                                                </span>
                                                                <span class="portfolio-project-open">
                                                                    Open
                                                                </span>
                                                            </div>
                                                        </div>
                                                    </a>
                                                );
                                            })}
                                        </div>

                                        <div
                                            class="portfolio-genre-brake"
                                            data-genre-brake
                                            aria-hidden="true"
                                        >
                                            <div class="portfolio-genre-brake-inner">
                                                <div class="portfolio-genre-brake-marquee portfolio-genre-brake-marquee--top">
                                                    <span>{genre}</span>
                                                    <span>{genre}</span>
                                                    <span>{genre}</span>
                                                    <span>{genre}</span>
                                                </div>
                                                <div class="portfolio-genre-brake-marquee portfolio-genre-brake-marquee--bottom">
                                                    <span>Next Field</span>
                                                    <span>{genre}</span>
                                                    <span>Pull Apart</span>
                                                    <span>{genre}</span>
                                                </div>
                                                <div class="portfolio-genre-brake-next">
                                                    <span>Next</span>
                                                    <strong>
                                                        {
                                                            orderedGroupedPortfolio[
                                                                genreIndex + 1
                                                            ]?.[0] || "Index"
                                                        }
                                                    </strong>
                                                </div>
                                            </div>
                                        </div>
                                    </section>
                                ),
                            )}
                        </div>
                    </main>
                </div>
            </div>
        )
    }
</Layout>
