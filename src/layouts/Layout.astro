                    const storageKey = "__portfolioRouteTransition";
                    const root = document.documentElement;
                    let isTransitioning = false;
                    let transitionTimer = 0;
                    let hasPlayedIncoming = false;

                    const setTransitionOrigin = (x = "50%", y = "50%") => {
